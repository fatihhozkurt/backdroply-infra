# Shared
APP_ENV=local
PUBLIC_APP_NAME=Backdroply
PUBLIC_BASE_URL=http://localhost:8080

# Postgres
POSTGRES_DB=bgremover
POSTGRES_USER=bgadmin
POSTGRES_PASSWORD=change_me_strong
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
BACKEND_JWT_SECRET=replace_with_a_very_long_random_secret_key_for_hs256_signing_123456
BACKEND_JWT_EXPIRES_MIN=120
BACKEND_ALLOWED_ORIGIN=http://localhost:5173
APP_STRICT_STARTUP=false
GOOGLE_CLIENT_ID=replace_google_client_id
ENGINE_BASE_URL=http://engine:9000
ENGINE_SHARED_TOKEN=replace_engine_shared_token
APP_ENGINE_PROCESS_TIMEOUT_SEC=900
DEFAULT_USER_TOKENS=5
TOKEN_COST_BALANCED=1
TOKEN_COST_ULTRA=2
SERVER_FORWARD_HEADERS_STRATEGY=framework
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SECURE_AUTO=true
AUTH_COOKIE_SAME_SITE=Lax
AUTH_COOKIE_DOMAIN=
RATE_LIMIT_AUTH_PER_MINUTE=24
RATE_LIMIT_PROCESS_PER_MINUTE=16
RATE_LIMIT_FRAME_EXTRACT_PER_MINUTE=36
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
APP_UPLOAD_MAX_IMAGE_MB=15
APP_UPLOAD_MAX_VIDEO_MB=120
APP_UPLOAD_SNIFF_BYTES=4096
APP_UPLOAD_STRICT_MAGIC=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@backdroply.local
PAYMENT_WEBHOOK_SECRET=replace_payment_webhook_secret
PAYMENT_WEBHOOK_TOLERANCE_SEC=300
PAYMENT_PROVIDER_NAME=iyzico
PAYMENT_PROVIDER_BASE_URL=https://sandbox-api.iyzipay.com
PAYMENT_PROVIDER_API_KEY=
PAYMENT_PROVIDER_SECRET_KEY=
PAYMENT_WEBHOOK_LOG_RETENTION_DAYS=45
STORAGE_ENABLED=false
STORAGE_PROVIDER=minio
STORAGE_BUCKET=backdroply-media
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PATH_STYLE=true
STORAGE_AUTO_CREATE_BUCKET=true
STORAGE_PUBLIC_BASE_URL=
STORAGE_SSE_ENABLED=false
STORAGE_SSE_MODE=AES256
STORAGE_SSE_KMS_KEY_ID=
PRIVACY_DELETION_PEPPER=replace_with_random_pepper

# Engine
ENGINE_PORT=9000
ENGINE_WORKDIR=/app/data
ENGINE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
ENGINE_MAX_IMAGE_MB=15
ENGINE_MAX_VIDEO_MB=120
ENGINE_MAX_VIDEO_SECONDS=18
ENGINE_MAX_IMAGE_PIXELS=8500000
ENGINE_MAX_VIDEO_PIXELS=2500000
ENGINE_DEFAULT_QUALITY=ultra
ENGINE_ALLOW_COLOR_BG=true
ENGINE_KEEP_JOBS_HOURS=12
ENGINE_WATERMARK_ENABLED=true
ENGINE_WATERMARK_TEXT=Made by Fatih
U2NET_HOME=/app/data/u2net
OMP_NUM_THREADS=1
OMP_THREAD_LIMIT=1
MALLOC_ARENA_MAX=2

# Web
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_GOOGLE_CLIENT_ID=replace_google_client_id
VITE_APP_NAME=Backdroply
