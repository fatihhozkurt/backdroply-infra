# Engine
ENGINE_PORT=9000
ENGINE_WORKDIR=/app/data
ENGINE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
ENGINE_MAX_IMAGE_MB=15
ENGINE_MAX_VIDEO_MB=120
ENGINE_MAX_VIDEO_SECONDS=18
ENGINE_MAX_IMAGE_PIXELS=8500000
ENGINE_MAX_VIDEO_PIXELS=2500000
ENGINE_DEFAULT_QUALITY=ultra
ENGINE_ALLOW_COLOR_BG=true
ENGINE_KEEP_JOBS_HOURS=12
ENGINE_WATERMARK_ENABLED=true
ENGINE_WATERMARK_TEXT=Made by Fatih
ENGINE_MODEL_CANDIDATES_ULTRA=u2netp
ENGINE_MODEL_CANDIDATES_BALANCED=u2netp
ENGINE_ULTRA_MAX_PASSES=5
ENGINE_TEMPORAL_FLOW_STRENGTH=0.22
ENGINE_EDGE_REFINE_STRENGTH=0.7
ENGINE_ENABLE_FRAME_RECHECK=true
ENGINE_RECHECK_EDGE_THRESHOLD=9.0
ENGINE_RECHECK_DISAGREEMENT_THRESHOLD=28.0
ENGINE_MAX_CONCURRENT_JOBS=2
ENGINE_QUEUE_WAIT_SECONDS=2.0
ENGINE_PREWARM_ON_STARTUP=true
ENGINE_PREWARM_QUALITY=ultra
ENGINE_ENABLE_GPU=false
ENGINE_ORT_RUNTIME=cpu
ENGINE_ORT_VERSION=1.22.0
ENGINE_ORT_PROVIDERS=
ENGINE_ORT_ALLOW_CPU_FALLBACK=true
ENGINE_ORT_RUNTIME_FLAVOR=cpu
ENGINE_UVICORN_WORKERS=
ENGINE_UVICORN_LIMIT_CONCURRENCY=
U2NET_HOME=/app/data/u2net
OMP_NUM_THREADS=1
OMP_THREAD_LIMIT=1
MALLOC_ARENA_MAX=2
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Web
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_GOOGLE_CLIENT_ID=replace_google_client_id
VITE_APP_NAME=Backdroply

